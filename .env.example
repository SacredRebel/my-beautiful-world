# --- Mailchimp (already live) ---
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=

# --- Paddle ---
# sandbox while testing, production when you go live
PADDLE_ENV=sandbox
# client-side token (test_... in sandbox, live_... in production) - safe in the browser
PADDLE_CLIENT_TOKEN=
# the price to sell, e.g. pri_01abc...
PADDLE_PRICE_ID=
# server-side API key - never expose
PADDLE_API_KEY=
# endpoint_secret_key from the notification destination - shown only once
PADDLE_WEBHOOK_SECRET=

# --- Private book storage (Supabase Storage) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
BOOK_BUCKET=books
BOOK_PATH=My-Beautiful-World.pdf
